# =============================================================================
# TrueFans SIGNAL — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# --- Environment mode ---
WEEKLYAMP_ENV=development           # "development" or "production" (enforces required config in prod)

# --- AI Provider (choose one or both) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Security (REQUIRED in production) ---
WEEKLYAMP_SECRET_KEY=               # Generate: python -c "import secrets; print(secrets.token_hex(32))"
WEEKLYAMP_ADMIN_HASH=               # Generate: weeklyamp security hash-password
WEEKLYAMP_ADMIN_PASSWORD=           # Alternative: plain password (hashed at runtime)

# --- Database ---
WEEKLYAMP_DB_PATH=data/weeklyamp.db
WEEKLYAMP_DB_BACKEND=sqlite         # "sqlite" or "postgres"
WEEKLYAMP_DATABASE_URL=             # PostgreSQL: postgresql://user:pass@localhost:5432/weeklyamp

# --- PostgreSQL Connection Pool (only for postgres backend) ---
PG_POOL_MIN=2                       # Minimum connections in pool
PG_POOL_MAX=10                      # Maximum connections in pool

# --- AI config ---
WEEKLYAMP_AI_PROVIDER=anthropic
WEEKLYAMP_AI_MODEL=claude-sonnet-4-5-20250929

# --- Site ---
WEEKLYAMP_SITE_DOMAIN=https://truefansnewsletters.com   # Used in sitemap, RSS, OG tags

# --- Session ---
WEEKLYAMP_SESSION_MAX_AGE=43200     # Session duration in seconds (default: 12 hours)

# --- Pagination ---
WEEKLYAMP_PAGINATION_DEFAULT=50     # Default number of items per page

# --- Request limits ---
WEEKLYAMP_MAX_REQUEST_BODY=1048576  # Max request body in bytes (default: 1 MB)

# --- Rate Limits ---
WEEKLYAMP_RATE_LOGIN_MAX=5          # Max login attempts per window
WEEKLYAMP_RATE_LOGIN_WINDOW=900     # Login rate limit window in seconds (15 min)
WEEKLYAMP_RATE_SUBSCRIBE_MAX=5      # Max subscribe attempts per window
WEEKLYAMP_RATE_SUBSCRIBE_WINDOW=900
WEEKLYAMP_RATE_SUBMIT_MAX=10        # Max submission attempts per window
WEEKLYAMP_RATE_SUBMIT_WINDOW=900

# --- Email / SMTP (optional) ---
WEEKLYAMP_EMAIL_ENABLED=false
WEEKLYAMP_SMTP_HOST=
WEEKLYAMP_SMTP_PORT=587
WEEKLYAMP_SMTP_USER=
WEEKLYAMP_SMTP_PASSWORD=
WEEKLYAMP_EMAIL_FROM=
WEEKLYAMP_EMAIL_FROM_NAME=TrueFans SIGNAL

# --- Submissions API ---
TRUEFANS_SUBMISSIONS_API_KEY=

# --- GoHighLevel (optional) ---
GHL_API_KEY=                        # GoHighLevel API Bearer token
GHL_LOCATION_ID=                    # GHL sub-account / location ID

# --- Social Media APIs (optional) ---
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# --- Logging ---
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=text                     # "text" or "json" (use json in production)

# --- Uvicorn (server) ---
PORT=8000
WEB_CONCURRENCY=1                   # Number of uvicorn workers
UVICORN_TIMEOUT_KEEP_ALIVE=5        # Keep-alive timeout in seconds
UVICORN_LIMIT_MAX_REQUESTS=0        # Restart worker after N requests (0 = disabled, set to 10000 for prod)
UVICORN_LIMIT_CONCURRENCY=0         # Max concurrent connections (0 = unlimited)

# --- Analytics ---
# WEEKLYAMP_PLAUSIBLE_DOMAIN=       # e.g. "truefansnewsletters.com" — leave empty to disable
