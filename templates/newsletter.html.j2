<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ newsletter_name }} — Issue #{{ issue_number }}</title>
    <style>
        {{ css }}
    </style>
</head>
<body>
    <div class="newsletter-wrapper">
        <div class="header" style="padding: 32px 0 28px; text-align: center;">
            <hr style="border: none; border-top: 1px solid #d1d5db; margin: 0 0 32px;">
            <div style="margin-bottom: 24px;">
                <span style="font-family: Georgia, 'Times New Roman', serif; font-size: 32px; color: #9ca3af; font-style: italic;">A TrueFans</span>
                <span style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; font-size: 38px; font-weight: 900; color: #1a1a1a; letter-spacing: 2px; margin-left: 10px;">NEWSLETTER</span>
            </div>
            <div style="font-family: Georgia, 'Times New Roman', serif; font-size: 14px; color: #9ca3af; font-style: italic; margin-bottom: 20px;">Part of the TrueFans Ecosystem&trade;</div>
        </div>

        {% if intro_copy %}
        <div class="intro-copy" style="padding: 24px 0 16px; border-bottom: 1px solid #e5e7eb; margin-bottom: 24px;">
            {{ intro_copy }}
        </div>
        {% endif %}

        {% for section in sections %}
        {{ section.html }}
        {% endfor %}

        {% if ps_closing %}
        <div class="ps-closing" style="margin-top: 32px; padding: 24px; background: #f9fafb; border-radius: 8px; border-left: 4px solid #e8645a;">
            <p style="font-size: 15px; line-height: 1.7; color: #374151; margin: 0; font-style: italic;">{{ ps_closing }}</p>
        </div>
        {% endif %}

        <div class="footer">
            {% if footer_html %}
            {{ footer_html }}
            {% else %}
            <p>&copy; {{ newsletter_name }} | You received this because you subscribed.</p>
            {% endif %}
            <p><a href="{{ unsubscribe_url | default('#') }}">Unsubscribe</a></p>
        </div>
    </div>
</body>
</html>
