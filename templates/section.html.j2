<div class="section">
    <div class="section-title">{{ display_name }}</div>
    {% if headline %}
    <div class="section-headline">{{ headline }}</div>
    {% endif %}
    <div class="section-content">
        {{ content }}
    </div>
    {% if sources %}
    <div style="margin-top: 14px; padding-top: 10px; border-top: 1px solid #f0f0f0;">
        <div style="font-size: 11px; color: #b0b0b0; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;">Sources</div>
        {% for src in sources %}
        <div style="font-size: 12px; color: #9ca3af; line-height: 1.6;">
            {% if src.url %}<a href="{{ src.url }}" style="color: #9ca3af; text-decoration: underline;">{{ src.title }}</a>{% else %}{{ src.title }}{% endif %}{% if src.author %} — {{ src.author }}{% endif %}
        </div>
        {% endfor %}
    </div>
    {% endif %}
    {% if byline %}
    <div style="margin-top: 8px; font-size: 12px; color: #9ca3af; font-style: italic;">{{ byline }}</div>
    {% endif %}
</div>
