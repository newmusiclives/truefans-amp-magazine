<div style="margin:28px 0;padding:24px;background:#faf7f2;border:1px solid #e6ddce;border-left:4px solid #c8a15a;border-radius:8px;font-family:Georgia,'Times New Roman',serif;">
    {% if label %}
    <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:#b08a3e;margin-bottom:10px;font-family:Arial,sans-serif;">{{ label }}</div>
    {% endif %}
    {% if headline %}
    <div style="font-size:20px;font-weight:bold;color:#1a1a1a;margin-bottom:10px;line-height:1.3;">{{ headline }}</div>
    {% endif %}
    {% if body_html %}
    <div style="font-size:15px;color:#3a3a3a;line-height:1.6;margin-bottom:16px;">{{ body_html }}</div>
    {% endif %}
    {% if cta_url %}
    <a href="{{ cta_url }}" style="display:inline-block;padding:12px 28px;background:#1a1a1a;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:14px;font-family:Arial,sans-serif;">{{ cta_text or 'Learn more' }} &rarr;</a>
    {% endif %}
</div>
